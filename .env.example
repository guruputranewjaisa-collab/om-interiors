# Copy this file to .env and fill in your real values.
# Never commit the real .env file to a public repository.

# Port the server runs on
PORT=3000

# Admin dashboard login (visit /admin.html)
ADMIN_USER=admin
ADMIN_PASS=changeme123

# --- Email notifications (optional) ---
# If you leave these blank, the site still works and saves every
# inquiry to the database — you just won't get an email alert.
# For Gmail: use an "App Password", not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFY_EMAIL=hello@ominteriors.in
